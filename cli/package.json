{
  "name": "cli",
  "version": "0.1.5",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "run-agent": "tsx --env-file=../.env src/run-agent.ts"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.23",
    "@langchain/core": "^1.1.32",
    "@langchain/deepseek": "^1.0.17",
    "@langchain/langgraph": "^1.2.2",
    "@langchain/openai": "^1.2.13",
    "agent": "workspace:*",
    "chalk": "^5.4.1",
    "commander": "^14.0.3",
    "core": "workspace:*",
    "langchain": "^1.2.32",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "ora": "^8.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.0.0",
    "globals": "^17.4.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^2.0.0"
  }
}
